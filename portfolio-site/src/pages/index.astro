---
import BaseLayout from "../layouts/BaseLayout.astro";
import Stat from "../components/Stat.astro";
import StackPill from "../components/StackPill.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../site.config";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

const focus = [
  "Streaming + lakehouse architectures",
  "Cloud data platforms on Azure and AWS",
  "Analytics engineering with dbt + data contracts",
  "Applied AI for data engineering productivity",
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.name,
  jobTitle: siteConfig.title,
  url: Astro.site?.toString(),
  sameAs: [siteConfig.github, siteConfig.linkedin],
  knowsAbout: [
    "Data Engineering",
    "Apache Spark",
    "Azure Databricks",
    "PySpark",
    "dbt",
    "Apache Airflow",
    "Snowflake",
    "Delta Lake",
    "Apache Iceberg",
    "Apache Kafka",
  ],
};
---

<BaseLayout
  title={`${siteConfig.name} - ${siteConfig.title}`}
  description={siteConfig.valueProp}
  jsonLd={jsonLd}
>
  <section id="hero" class="relative">
    <div class="absolute inset-0 grid-bg pointer-events-none" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-page px-6 pt-20 pb-20 md:pt-28 md:pb-24">
      <p class="font-mono text-xs uppercase tracking-widest text-muted">
        {siteConfig.tagline}
      </p>
      <h1 class="mt-4 text-4xl md:text-6xl font-semibold tracking-tight max-w-prose">
        {siteConfig.name}
      </h1>
      <p class="mt-5 max-w-prose text-lg text-muted">
        {siteConfig.valueProp}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/projects">View projects</a>
        <a class="btn" href={siteConfig.resumePath}>Download resume</a>
        <a class="btn" href="/contact">Contact me</a>
        <a class="btn" href={siteConfig.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a class="btn" href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-page px-6 pb-16">
    <div class="grid gap-4 md:grid-cols-3">
      <Stat value="$900K+/yr" label="Fraud-loss reduction identified or enabled" />
      <Stat value="$2.2B+" label="Portfolio supported by analytics systems" />
      <Stat value="6 yrs" label="AT&T · Azure · Databricks · BI platforms" />
    </div>
  </section>

  <section class="mx-auto max-w-page px-6 pb-24">
    <div class="flex items-end justify-between mb-6">
      <h2 class="text-xl font-semibold tracking-tight">Featured projects</h2>
      <a href="/projects" class="text-sm text-muted hover:text-fg">All projects <span aria-hidden="true">&rarr;</span></a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {projects.map((p) => (
        <div class="card-glow rounded-lg">
          <ProjectCard
            slug={p.slug}
            title={p.data.title}
            tagline={p.data.tagline}
            stack={p.data.stack}
            repoUrl={p.data.repoUrl}
          />
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-prose px-6 pb-16">
    <h2 class="text-xl font-semibold tracking-tight">About</h2>
    <p class="mt-3 text-muted">
      I'm a senior data and analytics engineer with six years at AT&T building
      production data platforms on Azure and Databricks. My work spans PySpark
      ingestion, dbt analytics models, BI delivery, streaming systems, and data
      quality. I specialize in turning ambiguous fraud, revenue, and operational
      problems into reliable pipelines and decision-ready analytics.
    </p>
    <h3 class="mt-6 text-sm font-mono uppercase tracking-widest text-muted">
      Certifications
    </h3>
    <ul class="mt-3 flex flex-wrap gap-1.5">
      <li><span class="pill">DP-203 · Azure Data Engineering</span></li>
      <li><span class="pill">DP-100 · Azure AI Engineering</span></li>
    </ul>
    <h3 class="mt-8 text-sm font-mono uppercase tracking-widest text-muted">
      Current focus
    </h3>
    <ul class="mt-3 space-y-1.5 text-sm">
      {focus.map((f) => (
        <li class="flex gap-2"><span class="text-accent" aria-hidden="true">&rarr;</span><span>{f}</span></li>
      ))}
    </ul>
    <h3 class="mt-8 text-sm font-mono uppercase tracking-widest text-muted">
      Stack
    </h3>
    <ul class="mt-3 flex flex-wrap gap-1.5">
      {[
        "PySpark",
        "Databricks",
        "Azure Data Factory",
        "Delta Lake",
        "Apache Iceberg",
        "Snowflake",
        "dbt",
        "Apache Airflow",
        "Apache Kafka",
        "Python",
        "SQL",
        "Terraform",
      ].map((s) => <li><StackPill label={s} /></li>)}
    </ul>
  </section>

  <section class="mx-auto max-w-page px-6 pb-24">
    <div class="card-glow rounded-lg border border-border p-8 md:p-10">
      <h2 class="text-xl md:text-2xl font-semibold tracking-tight max-w-prose">
        Interested in data platforms, analytics engineering, or BI automation?
      </h2>
      <p class="mt-3 max-w-prose text-muted">
        I'm open to senior data engineering, analytics engineering, and data
        platform consulting conversations.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/contact">Contact me</a>
        <a class="btn" href={siteConfig.resumePath}>View resume</a>
        <a class="btn" href={siteConfig.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const hero = document.getElementById("hero");
  if (hero) {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduceMotion) {
      let frame = 0;
      hero.addEventListener("mousemove", (e) => {
        if (frame) return;
        frame = requestAnimationFrame(() => {
          const rect = hero.getBoundingClientRect();
          const x = (e as MouseEvent).clientX - rect.left;
          const y = (e as MouseEvent).clientY - rect.top;
          hero.style.setProperty("--mouse-x", `${x}px`);
          hero.style.setProperty("--mouse-y", `${y}px`);
          frame = 0;
        });
      });
    }
  }
</script>
