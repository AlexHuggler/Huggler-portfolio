---
import BaseLayout from "../layouts/BaseLayout.astro";
import StackPill from "../components/StackPill.astro";
import FeaturedProjectCard from "../components/FeaturedProjectCard.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../site.config";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

/**
 * Project-level framing for the homepage cards. Kept here (not in the
 * MDX frontmatter) because these copy points are specifically tuned for
 * the homepage's skim-first reading order — the dedicated project pages
 * carry their own longer-form architecture write-ups.
 */
const featuredFraming: Record<
  string,
  { problem: string; technical: string; demonstrates: string[] }
> = {
  "fraud-signals": {
    problem:
      "Simulates fraud-event detection across streaming telecom-style data, with rules + statistical anomalies surfaced in seconds.",
    technical:
      "Kafka → Spark Structured Streaming → Delta → dbt → Streamlit, with watermarked windows, exactly-once writes, and dbt tests on the marts.",
    demonstrates: [
      "Streaming ingestion + watermarks",
      "Data quality / dbt tests",
      "Fraud analytics architecture",
      "Production-style local dev",
    ],
  },
  "telecom-lakehouse": {
    problem:
      "Builds a single source of truth for revenue, ARPU, and churn signals over high-volume Call Detail Record data.",
    technical:
      "Airflow → MinIO/S3 → Iceberg Bronze/Silver/Gold → Great Expectations contracts → dbt marts, with Terraform for the AWS variant.",
    demonstrates: [
      "Medallion lakehouse design",
      "Data contracts at the boundary",
      "dbt modeling for BI",
      "Orchestration + IaC",
    ],
  },
  "ai-sql-optimizer": {
    problem:
      "Closes the gap between “a query that runs” and “a query a senior would ship” for Spark SQL and Snowflake workloads.",
    technical:
      "sqlglot AST + heuristic findings feed a structured Claude prompt; optional EXPLAIN runner scores rewrites against a 50-query corpus.",
    demonstrates: [
      "Applied LLM tooling",
      "SQL parsing + heuristics",
      "Benchmark methodology",
      "Engineer-in-the-loop UX",
    ],
  },
};

const focus = [
  "Streaming + lakehouse architectures",
  "Cloud data platforms on Azure and AWS",
  "Analytics engineering with dbt + data contracts",
  "Applied AI for data engineering productivity",
];

const stack = [
  "PySpark",
  "Databricks",
  "Azure Data Factory",
  "Delta Lake",
  "Apache Iceberg",
  "Snowflake",
  "dbt",
  "Apache Airflow",
  "Apache Kafka",
  "Python",
  "SQL",
  "Terraform",
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: siteConfig.name,
  jobTitle: siteConfig.title,
  url: Astro.site?.toString(),
  sameAs: [siteConfig.github, siteConfig.linkedin],
  knowsAbout: [
    "Data Engineering",
    "Apache Spark",
    "Azure Databricks",
    "PySpark",
    "dbt",
    "Apache Airflow",
    "Snowflake",
    "Delta Lake",
    "Apache Iceberg",
    "Apache Kafka",
  ],
};
---

<BaseLayout
  title={`${siteConfig.name} - ${siteConfig.title}`}
  description={siteConfig.valueProp}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section id="hero" class="relative">
    <div class="absolute inset-0 grid-bg pointer-events-none" aria-hidden="true"></div>
    <div class="grid-bg-hot" aria-hidden="true"></div>
    <div class="hero-glow" aria-hidden="true"></div>
    <span class="hero-node" style="top: 22%; left: 12%; animation-delay: 0s;" aria-hidden="true"></span>
    <span class="hero-node" style="top: 68%; left: 28%; animation-delay: 1.6s;" aria-hidden="true"></span>
    <span class="hero-node" style="top: 38%; right: 14%; animation-delay: 3.0s;" aria-hidden="true"></span>
    <span class="hero-node" style="top: 80%; right: 22%; animation-delay: 4.4s;" aria-hidden="true"></span>
    <div class="relative mx-auto max-w-page px-6 pt-16 pb-16 md:pt-24 md:pb-20">
      <p class="font-mono text-xs uppercase tracking-widest text-muted">
        {siteConfig.tagline}
      </p>
      <h1 class="mt-4 text-4xl md:text-6xl font-semibold tracking-tight max-w-prose">
        {siteConfig.name}
      </h1>
      <p class="mt-5 max-w-prose text-lg text-muted leading-relaxed">
        {siteConfig.valueProp}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/projects">View projects</a>
        <a class="btn" href={siteConfig.resumePath}>Download resume</a>
        <a class="btn" href="/contact">Contact me</a>
        <a
          class="btn"
          href={siteConfig.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Alex's GitHub profile (opens in new tab)"
        >
          GitHub
        </a>
        <a
          class="btn"
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Alex's LinkedIn profile (opens in new tab)"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section
    class="mx-auto max-w-page px-6 pt-4 pb-20 md:pt-6 md:pb-24"
    aria-labelledby="featured-heading"
  >
    <div class="flex items-end justify-between mb-6">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-muted">
          Selected work
        </p>
        <h2
          id="featured-heading"
          class="mt-2 text-xl md:text-2xl font-semibold tracking-tight"
        >
          Featured projects
        </h2>
      </div>
      <a
        href="/projects"
        class="text-sm text-muted hover:text-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-sm"
        aria-label="View all projects"
      >
        All projects
        <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {projects.map((p, i) => {
        const framing = featuredFraming[p.slug];
        if (!framing) return null;
        return (
          <FeaturedProjectCard
            slug={p.slug}
            index={i + 1}
            title={p.data.title}
            problem={framing.problem}
            technical={framing.technical}
            demonstrates={framing.demonstrates}
            stack={p.data.stack}
            repoUrl={p.data.repoUrl}
          />
        );
      })}
    </div>
  </section>

  <!-- About + current focus + stack -->
  <section
    class="mx-auto max-w-prose px-6 pb-20"
    aria-labelledby="about-heading"
  >
    <p class="font-mono text-xs uppercase tracking-widest text-muted">About</p>
    <h2
      id="about-heading"
      class="mt-2 text-xl md:text-2xl font-semibold tracking-tight"
    >
      Senior data &amp; analytics engineer
    </h2>
    <div class="mt-4 space-y-4 text-muted leading-relaxed">
      <p>
        I'm a senior data and analytics engineer with six years at AT&amp;T
        building production data platforms on Azure and Databricks. My work
        spans PySpark ingestion, dbt analytics models, BI delivery, streaming
        systems, and data quality. I specialize in turning ambiguous fraud,
        revenue, and operational problems into reliable pipelines and
        decision-ready analytics.
      </p>
      <p>
        Recent impact includes identifying or enabling
        <span class="text-fg">$900K+/yr</span> in fraud-loss reduction and
        supporting analytics for a
        <span class="text-fg">$2.2B</span> portfolio of revenue and operational
        data — work that spans streaming detection, lakehouse design, and BI
        delivery on AT&amp;T's data platform.
      </p>
      <p>
        I treat tests, observability, runbooks, and data contracts as part of
        the deliverable, not as follow-ups. The projects above demonstrate that
        approach end-to-end: streaming pipelines with watermarks and
        exactly-once semantics, lakehouses with data quality at the boundary,
        and AI tooling with corpus-tested behavior.
      </p>
    </div>
    <div class="mt-5 flex flex-wrap items-center gap-2">
      <span class="font-mono text-[11px] uppercase tracking-widest text-muted">
        Certified
      </span>
      <span class="pill"><span class="text-accent">DP-203</span>&nbsp;Azure Data Engineering</span>
      <span class="pill"><span class="text-accent">DP-100</span>&nbsp;Azure AI Engineering</span>
    </div>

    <h3 class="mt-10 text-sm font-mono uppercase tracking-widest text-muted">
      Current focus
    </h3>
    <ul class="mt-3 grid gap-2 sm:grid-cols-2">
      {focus.map((f) => (
        <li class="focus-item">{f}</li>
      ))}
    </ul>

    <h3 class="mt-10 text-sm font-mono uppercase tracking-widest text-muted">
      Stack
    </h3>
    <ul class="mt-3 flex flex-wrap gap-1.5">
      {stack.map((s) => <li><StackPill label={s} /></li>)}
    </ul>
  </section>

  <!-- Contact CTA -->
  <section
    class="mx-auto max-w-page px-6 pb-24"
    aria-labelledby="contact-cta-heading"
  >
    <div class="card-glow spotlight-card rounded-lg border border-border p-8 md:p-10">
      <p class="font-mono text-xs uppercase tracking-widest text-muted">
        Let's talk
      </p>
      <h2
        id="contact-cta-heading"
        class="mt-2 text-xl md:text-2xl font-semibold tracking-tight max-w-prose"
      >
        Interested in data platforms, analytics engineering, or BI automation?
      </h2>
      <p class="mt-3 max-w-prose text-muted leading-relaxed">
        I'm open to senior data engineering, analytics engineering, and data
        platform consulting conversations.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/contact">Contact me</a>
        <a class="btn" href={siteConfig.resumePath}>View resume</a>
        <a
          class="btn"
          href={siteConfig.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Alex's GitHub profile (opens in new tab)"
        >
          GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  /**
   * Cursor-reactive UI. Two pieces:
   *
   *   1. Hero glow + grid-bg-hot read --mouse-x / --mouse-y on the hero.
   *   2. .spotlight-card elements receive --mx / --my per-card via a
   *      single delegated pointermove listener bound to the document.
   *
   * Both bail on (pointer: coarse) and (prefers-reduced-motion: reduce);
   * the matching CSS hides the effects under reduced motion as a belt
   * and braces. Listeners re-bind on astro:after-swap.
   */
  const cursorEffectsEnabled = () => {
    if (typeof window === "undefined") return false;
    if (window.matchMedia("(pointer: coarse)").matches) return false;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return false;
    return true;
  };

  const bindHeroGlow = () => {
    const hero = document.getElementById("hero");
    if (!hero || hero.dataset.glowBound === "true") return;
    if (!cursorEffectsEnabled()) return;
    hero.dataset.glowBound = "true";
    let frame = 0;
    hero.addEventListener("pointermove", (e) => {
      if (frame) return;
      frame = requestAnimationFrame(() => {
        const rect = hero.getBoundingClientRect();
        const x = (e as PointerEvent).clientX - rect.left;
        const y = (e as PointerEvent).clientY - rect.top;
        hero.style.setProperty("--mouse-x", `${x}px`);
        hero.style.setProperty("--mouse-y", `${y}px`);
        frame = 0;
      });
    });
  };

  const bindSpotlights = () => {
    const root = document.documentElement;
    if (root.dataset.spotlightBound === "true") return;
    if (!cursorEffectsEnabled()) return;
    root.dataset.spotlightBound = "true";

    let frame = 0;
    let pending: PointerEvent | null = null;

    document.addEventListener(
      "pointermove",
      (event) => {
        pending = event as PointerEvent;
        if (frame) return;
        frame = requestAnimationFrame(() => {
          frame = 0;
          const e = pending;
          if (!e) return;
          const card = (e.target as Element | null)?.closest?.(
            ".spotlight-card",
          ) as HTMLElement | null;
          if (!card) return;
          const rect = card.getBoundingClientRect();
          card.style.setProperty("--mx", `${e.clientX - rect.left}px`);
          card.style.setProperty("--my", `${e.clientY - rect.top}px`);
        });
      },
      { passive: true },
    );
  };

  bindHeroGlow();
  bindSpotlights();
  document.addEventListener("astro:after-swap", () => {
    bindHeroGlow();
    bindSpotlights();
  });
</script>
