---
import { siteConfig } from "../site.config";
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto max-w-page px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-muted">
    <p>{`Built by ${siteConfig.name}. MIT licensed.`}</p>
    <div class="flex items-center gap-4">
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="hover:text-fg">GitHub</a>
      <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-fg">LinkedIn</a>
      <a href={siteConfig.resumePath} class="hover:text-fg">Resume</a>
    </div>
  </div>
</footer>
