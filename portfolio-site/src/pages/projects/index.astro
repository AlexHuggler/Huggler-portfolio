---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectPreviewCard from "../../components/shared/ProjectPreviewCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

function previewFor(slug: string): string {
  return slug;
}
---

<BaseLayout
  title="Projects"
  description="Production data engineering portfolio: streaming pipelines, lakehouse architectures, and AI tooling."
>
  <section class="mx-auto max-w-page px-6 pt-16 pb-8">
    <p class="font-mono text-xs uppercase tracking-widest text-muted">Projects</p>
    <h1 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">Selected work</h1>
    <p class="mt-3 max-w-prose text-muted">
      Three end-to-end projects showcasing streaming, lakehouse, and AI-assisted
      data engineering. Each repo runs locally without external services. Click
      any card for a live, interactive walkthrough of the architecture.
    </p>
  </section>

  <section class="mx-auto max-w-page px-6 pb-24">
    <div class="grid gap-5 lg:grid-cols-3">
      {projects.map((p, i) => (
        <ProjectPreviewCard
          slug={p.slug}
          number={String(i + 1).padStart(2, "0")}
          title={p.data.title}
          tagline={p.data.tagline}
          stack={p.data.stack}
          repoUrl={p.data.repoUrl}
        >
          {previewFor(p.slug) === "fraud-signals" && (
            <svg
              slot="preview"
              role="img"
              aria-label="Pipeline preview: producer to Kafka to Spark to Delta to dbt to dashboard"
              viewBox="0 0 320 120"
              class="w-full h-full"
            >
              <defs>
                <linearGradient id="fp-track" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="rgba(37,99,235,0.05)" />
                  <stop offset="100%" stop-color="rgba(37,99,235,0.45)" />
                </linearGradient>
              </defs>
              {[28, 80, 132, 184, 236, 288].map((cx) => (
                <g>
                  <circle cx={cx} cy={60} r={12} fill="rgba(15,23,42,0.85)" stroke="rgba(148,163,184,0.45)" />
                </g>
              ))}
              <line x1={28} y1={60} x2={288} y2={60} stroke="url(#fp-track)" stroke-width={2} />
              {[52, 110, 160, 220].map((cx, i) => (
                <circle cx={cx} cy={60} r={3} fill={i === 1 ? "#ef4444" : "#2563eb"} opacity={0.85} />
              ))}
            </svg>
          )}
          {previewFor(p.slug) === "telecom-lakehouse" && (
            <svg
              slot="preview"
              role="img"
              aria-label="Medallion architecture preview: Bronze, Silver, Gold tiers"
              viewBox="0 0 320 120"
              class="w-full h-full"
            >
              <rect x={20} y={14}  width={280} height={26} rx={4} fill="#b45309" opacity={0.55} />
              <rect x={20} y={48}  width={280} height={26} rx={4} fill="#94a3b8" opacity={0.45} />
              <rect x={20} y={82}  width={280} height={26} rx={4} fill="#f59e0b" opacity={0.55} />
              <text x={28} y={32}  font-family="JetBrains Mono, ui-monospace, monospace" font-size="11" fill="#fef3c7">BRONZE · raw landings</text>
              <text x={28} y={66}  font-family="JetBrains Mono, ui-monospace, monospace" font-size="11" fill="#e2e8f0">SILVER · cleansed events</text>
              <text x={28} y={100} font-family="JetBrains Mono, ui-monospace, monospace" font-size="11" fill="#fef3c7">GOLD · business marts</text>
            </svg>
          )}
          {previewFor(p.slug) === "ai-sql-optimizer" && (
            <pre slot="preview" class="m-0 w-full h-full p-4 text-[11px] leading-snug font-mono text-muted overflow-hidden whitespace-pre"
><span class="text-zinc-500">-- before</span>
SELECT *
FROM events
WHERE date_format(ts,'yyyy-MM') = '2026-04';

<span class="text-emerald-400/80">-- after</span>
SELECT * FROM events
WHERE ts &gt;= TIMESTAMP '2026-04-01'
  AND ts &lt;  TIMESTAMP '2026-05-01';</pre>
          )}
        </ProjectPreviewCard>
      ))}
    </div>
  </section>
</BaseLayout>
