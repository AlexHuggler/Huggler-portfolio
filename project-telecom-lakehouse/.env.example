# Copy to .env to override defaults. Required only for the AWS deploy path.

# AWS
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1
PROJECT=telecom-lakehouse
ENVIRONMENT=dev

# MinIO (local docker-compose)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio12345
AWS_ENDPOINT_URL=http://localhost:9000

# Airflow
AIRFLOW_UID=50000

# dbt -> Athena (only if you point dbt at AWS)
# DBT_ATHENA_DATABASE=telecom
# DBT_ATHENA_S3_STAGING_DIR=s3://my-athena-staging/
