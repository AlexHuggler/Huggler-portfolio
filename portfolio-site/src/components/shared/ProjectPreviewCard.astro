---
/**
 * ProjectPreviewCard
 *
 * Rich preview card for the /projects landing page. Hosts a small visual
 * preview slot, project copy, stack pills, and a CTA to the full
 * interactive demo. The preview renders as a static SVG / code snippet —
 * no React island here so the landing page stays zero-JS.
 */
import StackPill from "../StackPill.astro";

interface Props {
  slug: string;
  number: string;
  title: string;
  tagline: string;
  stack: string[];
  repoUrl: string;
  demonstrates?: string[];
}
const { slug, number, title, tagline, stack, repoUrl, demonstrates } = Astro.props;
---

<article class="spotlight-card group flex flex-col rounded-lg border border-border overflow-hidden hover:border-accent hover:shadow-[0_0_0_1px_rgba(37,99,235,0.15),0_14px_40px_-16px_rgba(37,99,235,0.30)] hover:-translate-y-0.5 motion-reduce:hover:translate-y-0 transition-[border-color,box-shadow,transform] duration-200">
  <div class="relative aspect-[5/3] border-b border-border bg-bg/30 grid place-items-center overflow-hidden">
    <slot name="preview" />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <p class="font-mono text-[11px] uppercase tracking-widest text-muted">
      Project {number}
    </p>
    <h3 class="mt-1 text-lg font-semibold tracking-tight">
      <a href={`/projects/${slug}`} class="hover:text-accent">{title}</a>
    </h3>
    <p class="mt-2 text-sm text-muted">{tagline}</p>
    {demonstrates && demonstrates.length > 0 && (
      <p class="mt-2 text-[11px] font-mono uppercase tracking-wider text-muted">
        {demonstrates.join(" · ")}
      </p>
    )}
    <ul class="mt-3 flex flex-wrap gap-1.5">
      {stack.slice(0, 5).map((s) => <li><StackPill label={s} /></li>)}
    </ul>
    <div class="mt-auto pt-4 flex items-center justify-between text-sm">
      <a
        href={`/projects/${slug}`}
        class="inline-flex items-center gap-1 text-accent hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-sm"
        aria-label={`Open the interactive demo for ${title}`}
      >
        View interactive demo
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs text-muted hover:text-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg rounded-sm"
        aria-label={`${title} GitHub repository (opens in new tab)`}
      >
        repo
      </a>
    </div>
  </div>
</article>
