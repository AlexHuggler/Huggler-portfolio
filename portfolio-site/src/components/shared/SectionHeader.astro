---
/**
 * SectionHeader
 *
 * Project-page section header with eyebrow, title, and optional supporting
 * description. Keeps spacing and typography consistent across the three
 * interactive demos.
 */
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  id?: string;
}
const { eyebrow, title, description, id } = Astro.props;
---

<header class="mb-6" id={id}>
  {eyebrow && (
    <p class="demo-eyebrow">{eyebrow}</p>
  )}
  <h2 class="mt-2 text-xl md:text-2xl font-semibold tracking-tight">{title}</h2>
  {description && (
    <p class="mt-2 max-w-prose text-sm text-muted">{description}</p>
  )}
</header>
