# Copy to .env and fill in for real cloud runs.
# All variables are optional for local demo (`make demo`).

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=tx-events
KAFKA_STARTING_OFFSETS=latest

# Storage
DELTA_PATH=data/delta/tx_events
CHECKPOINT_PATH=checkpoints/tx_events

# Streaming knobs
WATERMARK=2 minutes
TRIGGER_INTERVAL=10 seconds
MAX_OFFSETS_PER_TRIGGER=10000

# dbt -> Databricks (only if you point dbt at a real warehouse)
# DATABRICKS_HOST=your-workspace.cloud.databricks.com
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abc123
# DATABRICKS_TOKEN=dapi-xxxx
