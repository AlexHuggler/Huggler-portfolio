---
import ThemeToggle from "./ThemeToggle.astro";
import { siteConfig } from "../site.config";

const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/resume", label: "Resume" },
  { href: "/contact", label: "Contact" },
];
---

<header class="border-b border-border dark:border-border sticky top-0 z-30 backdrop-blur supports-[backdrop-filter]:bg-bg/70 dark:supports-[backdrop-filter]:bg-bg/70">
  <nav class="mx-auto flex max-w-page items-center justify-between px-6 py-4">
    <a href="/" class="font-semibold tracking-tight">{siteConfig.name}</a>
    <ul class="hidden md:flex items-center gap-6 text-sm">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-muted hover:text-fg dark:hover:text-fg"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="flex items-center gap-3">
      <a
        href={siteConfig.github}
        class="text-sm text-muted hover:text-fg"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
