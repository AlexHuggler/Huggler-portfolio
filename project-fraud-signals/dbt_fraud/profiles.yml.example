fraud:
  target: local
  outputs:
    local:
      type: duckdb
      path: "dev.duckdb"
      schema: main
      threads: 4
    databricks:
      type: databricks
      catalog: main
      schema: fraud
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4
