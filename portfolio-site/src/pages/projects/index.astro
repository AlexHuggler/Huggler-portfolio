---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectPreviewCard from "../../components/shared/ProjectPreviewCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

function previewFor(slug: string): string {
  return slug;
}

const demonstratesBySlug: Record<string, string[]> = {
  "fraud-signals": ["Streaming ingestion", "Data quality", "Fraud analytics"],
  "telecom-lakehouse": ["Lakehouse design", "Data contracts", "Medallion architecture"],
  "ai-sql-optimizer": ["LLM tooling", "SQL parsing", "Benchmark methodology"],
};

const pipelineNodes = [
  { x: 32,  label: "Kafka" },
  { x: 96,  label: "Spark" },
  { x: 160, label: "Delta" },
  { x: 224, label: "dbt" },
  { x: 288, label: "Streamlit" },
];
---

<BaseLayout
  title="Projects"
  description="Production data engineering portfolio: streaming pipelines, lakehouse architectures, and AI tooling."
>
  <section class="mx-auto max-w-page px-6 pt-16 pb-8">
    <p class="font-mono text-xs uppercase tracking-widest text-muted">Projects</p>
    <h1 class="mt-3 text-3xl md:text-4xl font-semibold tracking-tight">Selected work</h1>
    <p class="mt-3 max-w-prose text-muted leading-relaxed">
      Three end-to-end projects showcasing streaming, lakehouse, and
      AI-assisted data engineering. Each repo is designed to run locally
      with synthetic data. The AI-assisted optimizer includes local heuristic
      and mock-response workflows out of the box, with optional Claude
      integration when an <code class="font-mono text-xs">ANTHROPIC_API_KEY</code>
      is configured. Click any card for a live, interactive walkthrough of
      the architecture.
    </p>
  </section>

  <section class="mx-auto max-w-page px-6 pb-24">
    <div class="grid gap-5 lg:grid-cols-3">
      {projects.map((p, i) => (
        <ProjectPreviewCard
          slug={p.slug}
          number={String(i + 1).padStart(2, "0")}
          title={p.data.title}
          tagline={p.data.tagline}
          stack={p.data.stack}
          repoUrl={p.data.repoUrl}
          demonstrates={demonstratesBySlug[p.slug]}
        >
          {previewFor(p.slug) === "fraud-signals" && (
            <svg
              slot="preview"
              role="img"
              aria-label="Pipeline: Kafka to Spark to Delta to dbt to Streamlit dashboard"
              viewBox="0 0 320 120"
              class="w-full h-full"
            >
              <defs>
                <linearGradient id="fp-flow" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%"   stop-color="rgba(37,99,235,0.15)" />
                  <stop offset="50%"  stop-color="rgba(37,99,235,0.55)" />
                  <stop offset="100%" stop-color="rgba(37,99,235,0.15)" />
                </linearGradient>
                <marker id="fp-arrow" viewBox="0 0 8 8" refX="6" refY="4" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                  <path d="M0,0 L8,4 L0,8 Z" fill="rgba(148,163,184,0.7)" />
                </marker>
              </defs>

              {pipelineNodes.slice(0, -1).map((n, idx) => (
                <line
                  x1={n.x + 18}
                  y1={56}
                  x2={pipelineNodes[idx + 1].x - 18}
                  y2={56}
                  stroke="url(#fp-flow)"
                  stroke-width="1.5"
                  marker-end="url(#fp-arrow)"
                />
              ))}

              {pipelineNodes.map((n, idx) => (
                <g>
                  <rect
                    x={n.x - 18}
                    y={44}
                    width={36}
                    height={24}
                    rx={5}
                    fill="rgba(15,23,42,0.85)"
                    stroke={idx === 2 ? "rgba(37,99,235,0.85)" : "rgba(148,163,184,0.45)"}
                    stroke-width={idx === 2 ? 1.25 : 1}
                  />
                  <text
                    x={n.x}
                    y={92}
                    text-anchor="middle"
                    font-family="JetBrains Mono, ui-monospace, monospace"
                    font-size="10"
                    fill="#a1a1aa"
                  >{n.label}</text>
                </g>
              ))}

              <circle class="pipeline-flow-dot" cx="0" cy="56" r="2.5" fill="#2563eb">
                <animate
                  attributeName="cx"
                  values="32;96;160;224;288;32"
                  keyTimes="0;0.22;0.46;0.70;0.94;1"
                  dur="5s"
                  repeatCount="indefinite"
                />
                <animate
                  attributeName="opacity"
                  values="0;1;1;1;1;0"
                  keyTimes="0;0.05;0.46;0.85;0.94;1"
                  dur="5s"
                  repeatCount="indefinite"
                />
              </circle>
            </svg>
          )}
          {previewFor(p.slug) === "telecom-lakehouse" && (
            <svg
              slot="preview"
              role="img"
              aria-label="Medallion architecture: Bronze raw landings, Silver cleansed events, Gold business marts"
              viewBox="0 0 320 130"
              class="w-full h-full"
            >
              <defs>
                <linearGradient id="ml-bronze" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%"   stop-color="rgba(180, 83, 9, 0.45)" />
                  <stop offset="100%" stop-color="rgba(180, 83, 9, 0.18)" />
                </linearGradient>
                <linearGradient id="ml-silver" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%"   stop-color="rgba(148, 163, 184, 0.40)" />
                  <stop offset="100%" stop-color="rgba(148, 163, 184, 0.16)" />
                </linearGradient>
                <linearGradient id="ml-gold" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%"   stop-color="rgba(245, 158, 11, 0.55)" />
                  <stop offset="100%" stop-color="rgba(245, 158, 11, 0.22)" />
                </linearGradient>
                <linearGradient id="ml-flow" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stop-color="rgba(148, 163, 184, 0)" />
                  <stop offset="50%"  stop-color="rgba(148, 163, 184, 0.55)" />
                  <stop offset="100%" stop-color="rgba(148, 163, 184, 0)" />
                </linearGradient>
              </defs>

              {/* Bronze — narrowest layer (raw, messy, at the bottom of the funnel of trust) */}
              <g>
                <rect x={48} y={14}  width={224} height={26} rx={4}
                  fill="url(#ml-bronze)"
                  stroke="rgba(254, 215, 170, 0.35)" stroke-width="0.75" />
                <text x={58} y={31}
                  font-family="JetBrains Mono, ui-monospace, monospace"
                  font-size="10" font-weight="600" fill="#fbbf24" letter-spacing="0.6">BRONZE</text>
                <text x={264} y={31}
                  font-family="JetBrains Mono, ui-monospace, monospace"
                  font-size="9" fill="#a1a1aa" text-anchor="end">raw landings</text>
              </g>

              {/* Silver — slightly wider, validated */}
              <g>
                <rect x={36} y={50} width={248} height={26} rx={4}
                  fill="url(#ml-silver)"
                  stroke="rgba(241, 245, 249, 0.30)" stroke-width="0.75" />
                <text x={46} y={67}
                  font-family="JetBrains Mono, ui-monospace, monospace"
                  font-size="10" font-weight="600" fill="#e2e8f0" letter-spacing="0.6">SILVER</text>
                <text x={276} y={67}
                  font-family="JetBrains Mono, ui-monospace, monospace"
                  font-size="9" fill="#a1a1aa" text-anchor="end">cleansed events</text>
              </g>

              {/* Gold — widest, business-ready marts */}
              <g>
                <rect x={24} y={86} width={272} height={26} rx={4}
                  fill="url(#ml-gold)"
                  stroke="rgba(254, 243, 199, 0.35)" stroke-width="0.75" />
                <text x={34} y={103}
                  font-family="JetBrains Mono, ui-monospace, monospace"
                  font-size="10" font-weight="600" fill="#fcd34d" letter-spacing="0.6">GOLD</text>
                <text x={286} y={103}
                  font-family="JetBrains Mono, ui-monospace, monospace"
                  font-size="9" fill="#a1a1aa" text-anchor="end">business marts</text>
              </g>

              {/* Flow connectors — vertical lines on the right showing transformation */}
              <line x1={306} y1={40} x2={306} y2={50}
                stroke="url(#ml-flow)" stroke-width="1" />
              <line x1={306} y1={76} x2={306} y2={86}
                stroke="url(#ml-flow)" stroke-width="1" />

              <text x={120} y={126}
                font-family="JetBrains Mono, ui-monospace, monospace"
                font-size="8" fill="rgba(161, 161, 170, 0.7)"
                letter-spacing="0.4"
                aria-hidden="true">
                ingest → validate → model
              </text>
            </svg>
          )}
          {previewFor(p.slug) === "ai-sql-optimizer" && (
            <div
              slot="preview"
              class="w-full h-full p-3 grid grid-rows-2 gap-2 font-mono text-[10px] leading-snug"
              role="img"
              aria-label="Before / after SQL rewrite: replacing date_format with a sargable timestamp range filter for partition pruning"
            >
              <div class="relative rounded border border-red-500/30 bg-red-500/[0.04] pl-3 pr-2 py-1.5 overflow-hidden">
                <span class="absolute left-0 top-0 bottom-0 w-[2px] bg-red-500/80" aria-hidden="true"></span>
                <div class="flex items-center justify-between">
                  <p class="font-mono text-[9px] uppercase tracking-wider text-red-400/90">Before</p>
                  <p class="font-mono text-[9px] uppercase tracking-wider text-red-300/80">
                    full scan
                  </p>
                </div>
                <pre class="m-0 mt-0.5 whitespace-pre text-muted"><span class="text-sky-400/80">SELECT</span> *
<span class="text-sky-400/80">FROM</span> events
<span class="text-sky-400/80">WHERE</span> <span class="text-red-300/95 underline decoration-red-500/60 decoration-wavy underline-offset-2">date_format</span>(ts,<span class="text-amber-300/80">'yyyy-MM'</span>) = <span class="text-amber-300/80">'2026-04'</span>;</pre>
              </div>
              <div class="relative rounded border border-emerald-500/30 bg-emerald-500/[0.04] pl-3 pr-2 py-1.5 overflow-hidden">
                <span class="absolute left-0 top-0 bottom-0 w-[2px] bg-emerald-500/80" aria-hidden="true"></span>
                <div class="flex items-center justify-between">
                  <p class="font-mono text-[9px] uppercase tracking-wider text-emerald-400/90">After</p>
                  <p class="font-mono text-[9px] uppercase tracking-wider text-emerald-300/80">
                    partition prunes
                  </p>
                </div>
                <pre class="m-0 mt-0.5 whitespace-pre text-muted"><span class="text-sky-400/80">SELECT</span> * <span class="text-sky-400/80">FROM</span> events
<span class="text-sky-400/80">WHERE</span> ts &gt;= <span class="text-emerald-300/95">TIMESTAMP</span> <span class="text-amber-300/80">'2026-04-01'</span>
  <span class="text-sky-400/80">AND</span> ts &lt;  <span class="text-emerald-300/95">TIMESTAMP</span> <span class="text-amber-300/80">'2026-05-01'</span>;</pre>
              </div>
            </div>
          )}
        </ProjectPreviewCard>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  @media (prefers-reduced-motion: reduce) {
    .pipeline-flow-dot { animation: none !important; opacity: 0; }
    :global(.pipeline-flow-dot animate) { display: none; }
  }
</style>
