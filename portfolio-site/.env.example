# Copy to .env (gitignored) and fill in for local builds.
# Both vars are optional; the site builds without them.

# Cloudflare Web Analytics beacon token. When set, the base layout
# injects the cookieless beacon script. Get this from
# Cloudflare dashboard -> Web Analytics -> Add a site.
PUBLIC_CF_ANALYTICS_TOKEN=

# URL of the deployed sql-optimizer-proxy Cloudflare Worker. When set,
# the SQL optimizer demo gains a "Run live" path that POSTs to this
# endpoint instead of using the pre-computed fixture.
PUBLIC_LIVE_DEMO_URL=
